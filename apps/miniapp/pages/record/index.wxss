.record-page {
  background: var(--color-bg-page);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.record-fixed {
  flex-shrink: 0;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.month-nav {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-brand);
  font-size: 56rpx;
  line-height: 70rpx;
  text-align: center;
  border: 1rpx solid var(--color-divider);
}

.month-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.month-text {
  font-size: 44rpx;
  font-weight: 700;
}

.month-sub {
  margin-top: 6rpx;
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.summary-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.record-scroll {
  flex: 1;
  min-height: 0;
}

.summary-card {
  padding: 24rpx;
}

.summary-label {
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.summary-value {
  margin-top: 12rpx;
  color: var(--color-brand-deep);
  font-size: 40rpx;
  font-weight: 800;
}

.calendar {
  padding: 22rpx 16rpx;
  margin-bottom: 28rpx;
}

.week-row,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-cell {
  height: 42rpx;
  text-align: center;
  color: var(--color-text-sub);
  font-size: 22rpx;
}

.day-cell {
  height: 92rpx;
  margin: 4rpx;
  padding-top: 8rpx;
  border-radius: 18rpx;
  text-align: center;
  color: var(--color-text-main);
}

.day-cell--selected {
  background: var(--color-selected);
  border: 1rpx solid var(--color-brand);
}

.day-cell--today .day-num {
  color: var(--color-brand-deep);
  font-weight: 800;
}

.day-num {
  display: block;
  font-size: 26rpx;
}

.day-expense,
.day-income {
  display: block;
  margin-top: 2rpx;
  font-size: 18rpx;
  line-height: 20rpx;
}

.day-expense {
  color: var(--color-brand-deep);
}

.day-income {
  color: var(--color-income);
}

.bill-list {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.empty {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-sub);
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 16rpx;
}

.bill-group {
  margin-bottom: 28rpx;
}

.group-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 4rpx 12rpx;
}

.group-date {
  font-size: 30rpx;
  font-weight: 700;
}

.group-total {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
}

.expense-text {
  color: var(--color-brand-deep);
}

.income-text {
  color: var(--color-income);
}

.bill-group-card {
  overflow: hidden;
}

.bill-swipe-row {
  position: relative;
  overflow: hidden;
}

.bill-swipe-content {
  position: relative;
  z-index: 2;
  background: #ffffff;
  transition: transform 0.18s ease;
}

.bill-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
}

.bill-swipe-action {
  width: 144rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.bill-swipe-action--edit {
  background: var(--color-brand);
}

.bill-swipe-action--delete {
  background: var(--color-error);
}

.bill-item {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.bill-item:last-child {
  border-bottom: 0;
}

.bill-swipe-row .bill-item {
  border-bottom: 1rpx solid var(--color-divider);
}

.bill-swipe-row:last-child .bill-item {
  border-bottom: 0;
}

.bill-icon {
  width: 76rpx;
  height: 76rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: var(--color-selected);
  text-align: center;
  line-height: 76rpx;
  font-size: 36rpx;
}

.bill-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.bill-name {
  font-weight: 700;
}

.bill-meta,
.bill-account {
  margin-top: 4rpx;
  color: var(--color-text-sub);
  font-size: 22rpx;
}

.bill-amount {
  margin-left: 16rpx;
  color: var(--color-brand-deep);
  font-size: 30rpx;
  font-weight: 800;
}

.bill-amount--income {
  color: var(--color-income);
}
