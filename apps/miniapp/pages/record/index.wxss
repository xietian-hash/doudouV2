.record-page {
  background: var(--color-bg-page);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.record-fixed {
  flex-shrink: 0;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.month-nav {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-brand);
  font-size: 56rpx;
  line-height: 70rpx;
  text-align: center;
  border: 1rpx solid var(--color-divider);
}

.month-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.month-text {
  font-size: 44rpx;
  font-weight: 700;
}

.month-sub {
  margin-top: 6rpx;
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.summary-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.record-scroll {
  flex: 1;
  min-height: 0;
}

.summary-card {
  padding: 24rpx;
}

.summary-label {
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.summary-value {
  margin-top: 12rpx;
  color: var(--color-brand-deep);
  font-size: 40rpx;
  font-weight: 800;
}

.calendar {
  padding: 22rpx 16rpx;
  margin-bottom: 28rpx;
}

.week-row,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-cell {
  height: 42rpx;
  text-align: center;
  color: var(--color-text-sub);
  font-size: 22rpx;
}

.day-cell {
  height: 92rpx;
  margin: 4rpx;
  padding-top: 8rpx;
  border-radius: 18rpx;
  text-align: center;
  color: var(--color-text-main);
}

.day-cell--selected {
  background: var(--color-selected);
  border: 1rpx solid var(--color-brand);
}

.day-cell--today .day-num {
  color: var(--color-brand-deep);
  font-weight: 800;
}

.day-num {
  display: block;
  font-size: 26rpx;
}

.day-expense,
.day-income {
  display: block;
  margin-top: 2rpx;
  font-size: 18rpx;
  line-height: 20rpx;
}

.day-expense {
  color: var(--color-brand-deep);
}

.day-income {
  color: var(--color-income);
}

.bill-list {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.empty {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-sub);
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 16rpx;
}

.bill-group {
  margin-bottom: 28rpx;
}

.group-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 4rpx 12rpx;
}

.group-date {
  font-size: 30rpx;
  font-weight: 700;
}

.group-total {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
}

.expense-text {
  color: var(--color-brand-deep);
}

.income-text {
  color: var(--color-income);
}

.bill-group-card {
  overflow: hidden;
}

.bill-swipe-row {
  position: relative;
  overflow: hidden;
}

.bill-swipe-content {
  position: relative;
  z-index: 2;
  background: #ffffff;
  transition: transform 0.18s ease;
}

.bill-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
}

.bill-swipe-action {
  width: 144rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.bill-swipe-action--edit {
  background: var(--color-brand);
}

.bill-swipe-action--delete {
  background: var(--color-error);
}

.bill-item {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.bill-item:last-child {
  border-bottom: 0;
}

.bill-swipe-row .bill-item {
  border-bottom: 1rpx solid var(--color-divider);
}

.bill-swipe-row:last-child .bill-item {
  border-bottom: 0;
}

.bill-icon {
  width: 76rpx;
  height: 76rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: var(--color-selected);
  text-align: center;
  line-height: 76rpx;
  font-size: 36rpx;
}

.bill-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.bill-name {
  font-weight: 700;
}

.bill-meta,
.bill-account {
  margin-top: 4rpx;
  color: var(--color-text-sub);
  font-size: 22rpx;
}

.bill-amount {
  margin-left: 16rpx;
  color: var(--color-brand-deep);
  font-size: 30rpx;
  font-weight: 800;
}

.bill-amount--income {
  color: var(--color-income);
}

/* ── 语音录音 & 确认弹窗 ── */

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 5000;
  display: flex;
  align-items: flex-end;
  background: rgba(43, 74, 58, 0.45);
}

.sheet {
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100%;
  min-height: 884rpx;
  max-height: calc(86vh - env(safe-area-inset-bottom));
  padding: 36rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 40rpx 40rpx 0 0;
  background: #ffffff;
}

.sheet::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 50%;
  width: 80rpx;
  height: 8rpx;
  margin-left: -40rpx;
  border-radius: 999rpx;
  background: var(--color-divider);
}

.sheet--voice {
  max-height: 82vh;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 800;
}

.sheet-close {
  width: 64rpx;
  height: 64rpx;
  text-align: center;
  line-height: 58rpx;
  color: var(--color-text-sub);
  font-size: 48rpx;
}

.sheet-footer {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: auto;
  padding-top: 24rpx;
}

.voice-list {
  max-height: 760rpx;
}

.voice-item {
  padding: 20rpx 22rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 24rpx;
}

.voice-row {
  display: flex;
  justify-content: space-between;
  font-weight: 800;
}

.voice-amount {
  color: var(--color-brand-deep);
}

.voice-amount--income {
  color: var(--color-income);
}

.voice-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.voice-meta-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.voice-del-btn {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: #fff0f0;
  color: var(--color-error);
  font-size: 22rpx;
  font-weight: 700;
}

.voice-warn {
  display: block;
  margin-top: 8rpx;
  color: var(--color-warning);
  font-size: 24rpx;
}

.recording-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  min-height: 264rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 40rpx 40rpx 0 0;
  background: #ffffff;
}

.wave-box {
  height: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 32rpx;
  background: var(--color-meta);
}

.wave-bar {
  width: 10rpx;
  border-radius: 999rpx;
  background: rgba(93, 190, 136, 0.44);
}

.wave-bar--1 { height: 32rpx; }
.wave-bar--2 { height: 52rpx; background: rgba(93, 190, 136, 0.66); }
.wave-bar--3 { height: 76rpx; background: var(--color-brand); }
.wave-bar--4 { height: 100rpx; background: var(--color-brand-deep); }
.wave-bar--5 { height: 60rpx; background: rgba(93, 190, 136, 0.66); }
.wave-bar--6 { height: 40rpx; }
.wave-bar--7 { height: 88rpx; background: var(--color-brand); }
.wave-bar--8 { height: 112rpx; background: var(--color-brand-deep); }
.wave-bar--9 { height: 68rpx; background: rgba(93, 190, 136, 0.66); }
.wave-bar--10 { height: 48rpx; }

.recording-tips {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recording-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-sub);
  letter-spacing: 1rpx;
}

.recording-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.4;
  transition: opacity 0.18s ease;
}

.recording-tip--active { opacity: 1; }
.recording-tip--cancel { color: #b45f3b; }
.recording-tip--done { color: var(--color-brand-deep); }

.recording-panel--canceling {
  border-color: #ffb59a;
  background: #fff5f0;
}

.recording-panel--canceling .wave-box { background: #ffe8de; }
.recording-panel--canceling .wave-bar { background: rgba(255, 110, 64, 0.4); }
.recording-panel--canceling .wave-bar--3,
.recording-panel--canceling .wave-bar--7 { background: #ff7043; }
.recording-panel--canceling .wave-bar--4,
.recording-panel--canceling .wave-bar--8 { background: #e85d3a; }
.recording-panel--canceling .recording-hint { color: #b45f3b; }

.recording-icon-arrow {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.recording-icon-arrow::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 7rpx;
  width: 6rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #ff8a65;
}

.recording-icon-arrow::after {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 4rpx;
  width: 14rpx;
  height: 14rpx;
  border-left: 5rpx solid #ff8a65;
  border-top: 5rpx solid #ff8a65;
  transform: rotate(45deg);
}

.recording-icon-check {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--color-brand-deep);
  border-radius: 999rpx;
}

.recording-icon-check::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 7rpx;
  width: 12rpx;
  height: 7rpx;
  border-left: 4rpx solid var(--color-brand-deep);
  border-bottom: 4rpx solid var(--color-brand-deep);
  transform: rotate(-45deg);
}

.voice-parsing-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(43, 74, 58, 0.4);
}

.voice-parsing-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 36rpx 48rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(43, 74, 58, 0.18);
}

.voice-parsing-spinner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.voice-parsing-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: var(--color-brand);
  animation: voice-parsing-bounce 1.1s ease-in-out infinite;
}

.voice-parsing-dot--1 { animation-delay: 0s; }
.voice-parsing-dot--2 { animation-delay: 0.18s; }
.voice-parsing-dot--3 { animation-delay: 0.36s; }

.voice-parsing-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  letter-spacing: 1rpx;
}

@keyframes voice-parsing-bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
