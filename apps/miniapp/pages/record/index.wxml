<view class="page record-page">
  <view class="record-fixed">
  <view class="month-header">
    <view class="month-nav" bindtap="prevMonth">‹</view>
    <view class="month-title">
      <text class="month-text">{{year}}年{{month}}月</text>
      <text class="month-sub">{{selectedDate ? '已筛选单日账单' : '每一笔都是生活的印记'}}</text>
    </view>
    <view class="month-nav" bindtap="nextMonth">›</view>
  </view>

  <view class="summary-row">
    <view class="summary-card card">
      <view class="summary-label">今日支出</view>
      <view class="summary-value">¥{{todayExpense}}</view>
    </view>
    <view class="summary-card card">
      <view class="summary-label">本月支出</view>
      <view class="summary-value">¥{{monthExpense}}</view>
    </view>
  </view>
  </view>

  <scroll-view scroll-y class="record-scroll" enhanced show-scrollbar="{{false}}">
  <view class="calendar card">
    <view class="week-row">
      <text wx:for="{{weekdays}}" wx:key="*this" class="week-cell">{{item}}</text>
    </view>
    <view class="day-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="key"
        class="day-cell {{item.empty ? 'day-cell--empty' : ''}} {{item.selected ? 'day-cell--selected' : ''}} {{item.today ? 'day-cell--today' : ''}}"
        data-date="{{item.date}}"
        bindtap="selectDate"
      >
        <text class="day-num">{{item.day}}</text>
        <text wx:if="{{item.expense}}" class="day-expense">{{item.expense}}</text>
        <text wx:if="{{item.income}}" class="day-income">{{item.income}}</text>
      </view>
    </view>
  </view>

  <view class="bill-list">
    <view wx:if="{{groups.length === 0 && !loading}}" class="empty card">
      <image class="empty-icon" src="/assets/images/empty.png" mode="aspectFit" />
      <text>暂无账单</text>
    </view>
    <view wx:for="{{groups}}" wx:for-index="groupIndex" wx:key="date" class="bill-group">
      <view class="group-head">
        <text class="group-date">{{item.title}}</text>
        <view class="group-total">
          <text wx:if="{{item.expense > 0}}" class="expense-text">支出 ¥{{item.expenseText}}</text>
          <text wx:if="{{item.income > 0}}" class="income-text">收入 ¥{{item.incomeText}}</text>
        </view>
      </view>
      <view class="bill-group-card card">
        <view
          wx:for="{{item.items}}"
          wx:for-item="bill"
          wx:for-index="billIndex"
          wx:key="id"
          class="bill-swipe-row"
          data-group-index="{{groupIndex}}"
          data-bill-index="{{billIndex}}"
          bindtouchstart="onTouchStart"
          bindtouchmove="onTouchMove"
          bindtouchend="onTouchEnd"
          bindtouchcancel="onTouchEnd"
        >
          <view class="bill-swipe-actions">
            <view class="bill-swipe-action bill-swipe-action--edit" data-id="{{bill.id}}" catchtap="openEdit">编辑</view>
            <view class="bill-swipe-action bill-swipe-action--delete" data-id="{{bill.id}}" catchtap="deleteBill">删除</view>
          </view>
          <view class="bill-swipe-content" style="transform: translateX({{bill.slideX || 0}}rpx);">
            <view
              class="bill-item"
              data-id="{{bill.id}}"
              data-group-index="{{groupIndex}}"
              data-bill-index="{{billIndex}}"
              bindtap="openDetail"
            >
          <view class="bill-icon">{{bill.categoryIcon || '□'}}</view>
          <view class="bill-main">
            <text class="bill-name">{{bill.categoryName}}</text>
            <text class="bill-meta">{{bill.metaText}}</text>
          </view>
          <text class="{{bill.amountClass}}">{{bill.sign}}{{bill.amountText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  </scroll-view>

  <view wx:if="{{voiceConfirmVisible}}" class="sheet-mask" bindtap="closeVoiceConfirm">
    <view class="sheet sheet--voice" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">确认记账</text>
        <text class="sheet-close" bindtap="closeVoiceConfirm">×</text>
      </view>
      <scroll-view scroll-y class="voice-list">
        <view wx:for="{{voiceItems}}" wx:key="_localId" class="voice-item">
          <view class="voice-row">
            <text class="voice-cat">{{item.categoryText}}</text>
            <text class="{{item.amountClass}}">{{item.amountSign}}{{item.amount}}</text>
          </view>
          <view class="voice-bottom-row">
            <text class="voice-meta-text">{{item.metaText}}</text>
            <text class="voice-del-btn" data-id="{{item._localId}}" bindtap="removeVoiceItem">删除</text>
          </view>
          <text wx:if="{{item.needsConfirm}}" class="voice-warn">需要确认分类或金额</text>
        </view>
      </scroll-view>
      <view class="sheet-footer">
        <view class="secondary-btn" bindtap="closeVoiceConfirm">取消</view>
        <view class="primary-btn" bindtap="saveVoiceItems">确认保存</view>
      </view>
    </view>
  </view>

  <view wx:if="{{voiceParsing}}" class="voice-parsing-mask" catchtap="noop" catchtouchmove="noop">
    <view class="voice-parsing-card">
      <view class="voice-parsing-spinner">
        <view class="voice-parsing-dot voice-parsing-dot--1"></view>
        <view class="voice-parsing-dot voice-parsing-dot--2"></view>
        <view class="voice-parsing-dot voice-parsing-dot--3"></view>
      </view>
      <text class="voice-parsing-text">兜兜思考中...</text>
    </view>
  </view>

  <view wx:if="{{recording}}" class="{{recordingPanelClass}}">
    <view class="wave-box">
      <view class="wave-bar wave-bar--1"></view>
      <view class="wave-bar wave-bar--2"></view>
      <view class="wave-bar wave-bar--3"></view>
      <view class="wave-bar wave-bar--4"></view>
      <view class="wave-bar wave-bar--5"></view>
      <view class="wave-bar wave-bar--6"></view>
      <view class="wave-bar wave-bar--7"></view>
      <view class="wave-bar wave-bar--8"></view>
      <view class="wave-bar wave-bar--9"></view>
      <view class="wave-bar wave-bar--10"></view>
    </view>
    <view class="recording-hint">{{recordingHintText}}</view>
    <view class="recording-tips">
      <view class="{{cancelTipClass}}">
        <view class="recording-icon-arrow"></view>
        <text>{{cancelTipText}}</text>
      </view>
      <view class="{{doneTipClass}}">
        <view class="recording-icon-check"></view>
        <text>松开完成</text>
      </view>
    </view>
  </view>
</view>
