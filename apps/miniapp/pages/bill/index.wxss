page {
  height: 100vh;
  overflow: hidden;
}

.bill-page {
  background: var(--color-bg-bill);
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0 0 calc(580rpx + env(safe-area-inset-bottom));
}

.type-switch {
  display: flex;
  justify-content: center;
  height: 88rpx;
  background: #ffffff;
  border-bottom: 1rpx solid var(--color-divider);
}

.type-btn {
  position: relative;
  width: 200rpx;
  height: 88rpx;
  color: var(--color-text-sub);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.type-btn--active {
  color: var(--color-brand-deep);
}

.type-btn--income {
  color: var(--color-income);
}

.type-btn--active::after {
  content: "";
  position: absolute;
  left: 76rpx;
  right: 76rpx;
  bottom: 8rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.amount-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 40rpx;
  background: #ffffff;
  border-bottom: 1rpx solid var(--color-divider);
}

.amount-main {
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
}

.amount-unit {
  margin-right: 10rpx;
  color: var(--color-text-sub);
  font-size: 36rpx;
  font-weight: 800;
}

.amount-value {
  color: var(--color-text-main);
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
}

.selected-cat {
  display: flex;
  align-items: center;
  min-width: 0;
  border-radius: 999rpx;
  color: var(--color-brand-deep);
  font-size: 36rpx;
  font-weight: 800;
}

.selected-cat-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: var(--color-selected);
  text-align: center;
  line-height: 80rpx;
  font-size: 40rpx;
}

.selected-cat-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chev {
  margin-left: 8rpx;
  color: var(--color-text-sub);
  font-size: 24rpx;
  line-height: 1;
}

.category-scroll {
  flex: 1;
  min-height: 0;
  background: #ffffff;
}

.category-grid,
.section-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  padding: 20rpx 32rpx 28rpx;
}

.category-item {
  height: 124rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid transparent;
  border-radius: 20rpx;
  color: var(--color-text-sub);
}

.category-item--active {
  border-color: var(--color-brand);
  background: var(--color-selected);
  color: var(--color-brand-deep);
  font-weight: 700;
}

.category-icon {
  font-size: 40rpx;
  line-height: 44rpx;
}

.category-name {
  max-width: 120rpx;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
}

.bill-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 20;
  padding: 12rpx 32rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid var(--color-divider);
}

.bill-remark-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 64rpx;
  padding: 0 40rpx;
  margin-bottom: 8rpx;
  background: #ffffff;
}

.bill-remark-icon {
  width: 28rpx;
  height: 28rpx;
  font-size: 26rpx;
  color: var(--color-text-sub);
  line-height: 28rpx;
  text-align: center;
}

.bill-remark-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 26rpx;
  color: var(--color-text-main);
}

.bill-remark-placeholder {
  color: var(--color-text-weak);
  font-size: 26rpx;
}

.meta-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.meta-pill {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: var(--color-meta);
  color: var(--color-text-sub);
}

.meta-text {
  max-width: 86rpx;
  margin-left: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.keyboard {
  display: flex;
  gap: 12rpx;
}

.keyboard-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.key-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.keyboard-right {
  width: 144rpx;
  height: 324rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.key {
  height: 72rpx;
  border-radius: 16rpx;
  background: var(--color-surface-soft);
  text-align: center;
  line-height: 72rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.key--delete {
  background: var(--color-warning-soft);
  color: var(--color-warning);
}

.key--done {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-brand);
  color: #ffffff;
  line-height: 1.2;
  font-size: 20rpx;
}

.done-mark {
  margin-bottom: 8rpx;
  font-size: 36rpx;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 5000;
  display: flex;
  align-items: flex-end;
  background: rgba(43, 74, 58, 0.45);
}

.sheet {
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100%;
  min-height: 884rpx;
  max-height: calc(86vh - env(safe-area-inset-bottom));
  padding: 36rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 40rpx 40rpx 0 0;
  background: #ffffff;
}

.sheet::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 50%;
  width: 80rpx;
  height: 8rpx;
  margin-left: -40rpx;
  border-radius: 999rpx;
  background: var(--color-divider);
}

.sheet--voice {
  max-height: 82vh;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 800;
}

.sheet-close {
  width: 64rpx;
  height: 64rpx;
  text-align: center;
  line-height: 58rpx;
  color: var(--color-text-sub);
  font-size: 48rpx;
}

.sheet-scroll {
  max-height: 760rpx;
}

.sheet-scroll--small {
  max-height: 520rpx;
}

.section-title {
  margin: 18rpx 4rpx 8rpx;
  color: var(--color-text-sub);
  font-weight: 700;
}

.sheet-footer {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: auto;
  padding-top: 24rpx;
}

.account-item {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  margin-bottom: 12rpx;
}

.account-item--active {
  background: var(--color-selected);
}

.account-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
  line-height: 72rpx;
}

.account-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.account-name {
  font-weight: 700;
}

.account-sub {
  margin-top: 4rpx;
  color: var(--color-text-sub);
  font-size: 22rpx;
}

.check {
  color: var(--color-brand);
  font-size: 34rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: var(--color-surface-soft);
  color: var(--color-text-sub);
}

.tag-item--active {
  background: var(--color-selected);
  color: var(--color-brand-deep);
  font-weight: 700;
}

.date-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.date-head text:first-child,
.date-head text:last-child {
  width: 72rpx;
  text-align: center;
  color: var(--color-brand);
  font-size: 48rpx;
}

.date-week,
.date-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
}

.date-week {
  margin-top: 12rpx;
  color: var(--color-text-sub);
  font-size: 22rpx;
}

.date-day {
  height: 72rpx;
  margin: 6rpx;
  border-radius: 18rpx;
  line-height: 72rpx;
}

.date-day--selected {
  background: var(--color-brand);
  color: #ffffff;
  font-weight: 800;
}

.voice-list {
  max-height: 760rpx;
}

.voice-item {
  position: relative;
  padding: 22rpx 72rpx 22rpx 22rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 24rpx;
}

.voice-row {
  display: flex;
  justify-content: space-between;
  font-weight: 800;
}

.voice-amount {
  color: var(--color-brand-deep);
}

.voice-amount--income {
  color: var(--color-income);
}

.voice-remark,
.voice-warn {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.voice-warn {
  color: var(--color-warning);
}

.voice-delete {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 44rpx;
  height: 44rpx;
  color: var(--color-error);
  text-align: center;
  line-height: 40rpx;
  font-size: 40rpx;
}

.recording-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  min-height: 264rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 40rpx 40rpx 0 0;
  background: #ffffff;
}

.wave-box {
  height: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 32rpx;
  background: var(--color-meta);
}

.wave-bar {
  width: 10rpx;
  border-radius: 999rpx;
  background: rgba(93, 190, 136, 0.44);
}

.wave-bar--1 {
  height: 32rpx;
}

.wave-bar--2 {
  height: 52rpx;
  background: rgba(93, 190, 136, 0.66);
}

.wave-bar--3 {
  height: 76rpx;
  background: var(--color-brand);
}

.wave-bar--4 {
  height: 100rpx;
  background: var(--color-brand-deep);
}

.wave-bar--5 {
  height: 60rpx;
  background: rgba(93, 190, 136, 0.66);
}

.wave-bar--6 {
  height: 40rpx;
}

.wave-bar--7 {
  height: 88rpx;
  background: var(--color-brand);
}

.wave-bar--8 {
  height: 112rpx;
  background: var(--color-brand-deep);
}

.wave-bar--9 {
  height: 68rpx;
  background: rgba(93, 190, 136, 0.66);
}

.wave-bar--10 {
  height: 48rpx;
}

.recording-tips {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recording-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-2);
  letter-spacing: 1rpx;
}

.recording-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.4;
  transition: opacity 0.18s ease;
}

.recording-tip--active {
  opacity: 1;
}

.recording-tip--cancel {
  color: #b45f3b;
}

.recording-tip--done {
  color: var(--color-brand-deep);
}

.recording-panel--canceling {
  border-color: #ffb59a;
  background: #fff5f0;
}

.recording-panel--canceling .wave-box {
  background: #ffe8de;
}

.recording-panel--canceling .wave-bar {
  background: rgba(255, 110, 64, 0.4);
}

.recording-panel--canceling .wave-bar--3,
.recording-panel--canceling .wave-bar--7 {
  background: #ff7043;
}

.recording-panel--canceling .wave-bar--4,
.recording-panel--canceling .wave-bar--8 {
  background: #e85d3a;
}

.recording-panel--canceling .recording-hint {
  color: #b45f3b;
}

.recording-icon-arrow {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.recording-icon-arrow::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 7rpx;
  width: 6rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #ff8a65;
}

.recording-icon-arrow::after {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 4rpx;
  width: 14rpx;
  height: 14rpx;
  border-left: 5rpx solid #ff8a65;
  border-top: 5rpx solid #ff8a65;
  transform: rotate(45deg);
}

.recording-icon-check {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--color-brand-deep);
  border-radius: 999rpx;
}

.recording-icon-check::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 7rpx;
  width: 12rpx;
  height: 7rpx;
  border-left: 4rpx solid var(--color-brand-deep);
  border-bottom: 4rpx solid var(--color-brand-deep);
  transform: rotate(-45deg);
}

.voice-parsing-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(43, 74, 58, 0.4);
}

.voice-parsing-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 36rpx 48rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(43, 74, 58, 0.18);
}

.voice-parsing-spinner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.voice-parsing-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: var(--color-brand);
  animation: voice-parsing-bounce 1.1s ease-in-out infinite;
}

.voice-parsing-dot--1 {
  animation-delay: 0s;
}

.voice-parsing-dot--2 {
  animation-delay: 0.18s;
}

.voice-parsing-dot--3 {
  animation-delay: 0.36s;
}

.voice-parsing-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  letter-spacing: 1rpx;
}

@keyframes voice-parsing-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}
