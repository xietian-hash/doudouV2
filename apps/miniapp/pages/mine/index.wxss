.mine-page {
  min-height: 100vh;
  padding: 0;
  background: var(--color-bg-page);
}

.mine-hero {
  height: 320rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 40rpx 64rpx;
  color: #ffffff;
  background: linear-gradient(180deg, #4db87a 0%, #5dbe88 100%);
}

.hero-status {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 30rpx;
  font-weight: 600;
}

.hero-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 72rpx;
  background: #ffffff;
  color: var(--color-brand);
  box-shadow: 0 8rpx 32rpx rgba(43, 74, 58, 0.16);
  font-size: 52rpx;
  font-weight: 700;
}

.avatar-img {
  width: 144rpx;
  height: 144rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
}

.mine-content {
  height: calc(100vh - 320rpx);
  margin-top: -40rpx;
  padding: 40rpx 32rpx 150rpx;
  border-radius: 40rpx 40rpx 0 0;
  background: var(--color-bg-page);
}

.setting-section {
  overflow: hidden;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 40rpx rgba(43, 74, 58, 0.09);
}

.section-title {
  padding: 24rpx 32rpx 16rpx;
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.setting-item {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
}

.setting-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: var(--color-selected);
  color: var(--color-brand);
  font-size: 32rpx;
  font-weight: 700;
}

.setting-icon--muted {
  color: var(--color-text-sub);
}

.setting-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.setting-title {
  color: var(--color-text-main);
  font-size: 28rpx;
  font-weight: 700;
}

.setting-desc {
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.setting-arrow {
  color: var(--color-text-weak);
  font-size: 42rpx;
}

.section-divider {
  height: 1rpx;
  margin-left: 128rpx;
  background: var(--color-divider);
}

.import-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(43, 74, 58, 0.42);
}

.import-dialog {
  width: 670rpx;
  overflow: hidden;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 64rpx rgba(43, 74, 58, 0.18);
}

.import-head {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx 12rpx;
}

.import-title {
  color: var(--color-text-main);
  font-size: 34rpx;
  font-weight: 800;
}

.import-close {
  color: var(--color-text-sub);
  font-size: 44rpx;
  line-height: 44rpx;
}

.import-desc {
  display: block;
  padding: 0 40rpx;
  color: var(--color-text-sub);
  font-size: 26rpx;
  line-height: 1.6;
}

.import-url-box {
  margin: 28rpx 40rpx 0;
  padding: 24rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 24rpx;
  background: var(--color-surface-soft);
}

.import-url {
  color: var(--color-text-main);
  font-size: 24rpx;
  line-height: 1.55;
  word-break: break-all;
}

.import-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 40rpx;
}

.import-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.import-btn--secondary {
  border: 1rpx solid var(--color-divider);
  background: var(--color-bg-page);
  color: var(--color-brand);
}

.import-btn--primary {
  background: var(--color-brand);
  color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(43, 74, 58, 0.09);
}
