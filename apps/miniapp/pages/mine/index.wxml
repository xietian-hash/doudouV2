<view class="page mine-page">
  <view class="user-card card">
    <view class="avatar">
      <image wx:if="{{user.avatarUrl}}" class="avatar-img" src="{{user.avatarUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-text">兜</text>
    </view>
    <view class="user-main">
      <text class="user-name">{{user.nickname || '微信用户'}}</text>
      <text class="user-sub">安心记录每一笔生活流动</text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="goCategory">
      <text class="menu-icon">□</text>
      <view class="menu-main">
        <text class="menu-title">分类管理</text>
        <text class="menu-desc">维护收入和支出分类</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAccount">
      <text class="menu-icon">¥</text>
      <view class="menu-main">
        <text class="menu-title">账户管理</text>
        <text class="menu-desc">管理现金、银行卡和余额</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="goTag">
      <text class="menu-icon">#</text>
      <view class="menu-main">
        <text class="menu-title">标签管理</text>
        <text class="menu-desc">给账单补充场景标签</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <text class="version">兜兜有钱 v0.1.5</text>
</view>
