<view class="mine-page">
  <view class="mine-hero" style="padding-top: {{statusBarHeight}}px; height: calc(280rpx + {{statusBarHeight}}px);">
    <view class="hero-user">
      <view class="avatar">
        <image wx:if="{{user.avatarUrl}}" class="avatar-img" src="{{user.avatarUrl}}" mode="aspectFill" />
        <text wx:else>{{avatarText}}</text>
      </view>
      <text class="user-name">{{user.nickname || '微信用户'}}</text>
    </view>
  </view>

  <scroll-view class="mine-content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="setting-section">
      <view class="section-title">账本设置</view>
      <view class="setting-item" bindtap="goAccount">
        <view class="setting-icon">账</view>
        <view class="setting-main">
          <text class="setting-title">账户管理</text>
          <text class="setting-desc">现金、银行卡和支付账户</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="section-divider"></view>
      <view class="setting-item" bindtap="goCategory">
        <view class="setting-icon">类</view>
        <view class="setting-main">
          <text class="setting-title">分类管理</text>
          <text class="setting-desc">收入支出分类和二级分类</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="section-divider"></view>
      <view class="setting-item" bindtap="goTag">
        <view class="setting-icon">#</view>
        <view class="setting-main">
          <text class="setting-title">标签管理</text>
          <text class="setting-desc">常用场景和账单标签</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="section-divider"></view>
      <view class="setting-item" bindtap="goRecurringBills">
        <view class="setting-icon">循</view>
        <view class="setting-main">
          <text class="setting-title">重复账单</text>
          <text class="setting-desc">按日、月、年自动生成账单</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-section">
      <view class="section-title">数据工具</view>
      <view class="setting-item" bindtap="goStats">
        <view class="setting-icon setting-icon--muted">统</view>
        <view class="setting-main">
          <text class="setting-title">数据统计</text>
          <text class="setting-desc">分类占比、趋势、TOP 单笔</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="section-divider"></view>
      <view class="setting-item" bindtap="goImport">
        <view class="setting-icon setting-icon--muted">入</view>
        <view class="setting-main">
          <text class="setting-title">数据导入</text>
          <text class="setting-desc">用 Excel 模板批量导入历史账单</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="section-divider"></view>
      <view class="setting-item" bindtap="goExport">
        <view class="setting-icon setting-icon--muted">出</view>
        <view class="setting-main">
          <text class="setting-title">数据导出</text>
          <text class="setting-desc">导出账单明细</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-section">
      <view class="section-title">其他</view>
      <view class="setting-item" bindtap="goAbout">
        <view class="setting-icon setting-icon--muted">i</view>
        <view class="setting-main">
          <text class="setting-title">关于应用</text>
          <text class="setting-desc">兜兜有钱 v{{version}}</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="section-divider"></view>
      <view class="setting-item" bindtap="goFeedback">
        <view class="setting-icon setting-icon--muted">言</view>
        <view class="setting-main">
          <text class="setting-title">意见反馈</text>
          <text class="setting-desc">帮助我们改进体验</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>
    <view class="mine-bottom-spacer"></view>
  </scroll-view>

</view>
