.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
}

.primary-small {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: var(--color-brand);
  color: #ffffff;
  line-height: 64rpx;
  font-weight: 700;
}

.item {
  min-height: 116rpx;
  display: flex;
  align-items: center;
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 18rpx;
  border-radius: 24rpx;
  background: var(--color-selected);
  text-align: center;
  line-height: 72rpx;
}

.item-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-weight: 800;
}

.item-sub {
  margin-top: 4rpx;
  color: var(--color-text-sub);
  font-size: 24rpx;
}

.item-action,
.item-delete {
  margin-left: 18rpx;
  color: var(--color-brand);
  font-size: 24rpx;
}

.item-delete {
  color: var(--color-error);
}

.dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(43, 74, 58, 0.42);
}

.dialog {
  width: 670rpx;
  padding: 32rpx;
}

.dialog-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 36rpx;
  font-weight: 800;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 24rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.type-item {
  height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: var(--color-surface-soft);
  color: var(--color-text-sub);
  font-size: 20rpx;
}

.type-item--active {
  background: var(--color-selected);
  color: var(--color-brand-deep);
  font-weight: 700;
}

.dialog-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}
