<view class="page manage-page">
  <view class="head-row">
    <text class="title">账户</text>
    <view class="primary-small" bindtap="openCreate">新增账户</view>
  </view>
  <view wx:for="{{accounts}}" wx:key="id" class="item card">
    <text class="item-icon">{{item.icon || '💳'}}</text>
    <view class="item-main">
      <text class="item-title">{{item.name}}</text>
      <text class="item-sub">{{item.isDefault ? '默认账户 · ' : ''}}余额 ¥{{item.balance}}</text>
    </view>
    <text class="item-action" data-id="{{item.id}}" bindtap="setDefault">默认</text>
    <text class="item-delete" data-id="{{item.id}}" bindtap="remove">删除</text>
  </view>

  <view wx:if="{{dialogVisible}}" class="dialog-mask">
    <view class="dialog card">
      <text class="dialog-title">新增账户</text>
      <input class="input" value="{{form.name}}" bindinput="onNameInput" placeholder="账户名称" />
      <view class="type-grid">
        <view wx:for="{{types}}" wx:key="value" class="type-item {{form.type === item.value ? 'type-item--active' : ''}}" data-type="{{item.value}}" bindtap="selectType">
          <text>{{item.icon}}</text>
          <text>{{item.label}}</text>
        </view>
      </view>
      <view class="dialog-actions">
        <view class="secondary-btn" bindtap="closeDialog">取消</view>
        <view class="primary-btn" bindtap="save">确认</view>
      </view>
    </view>
  </view>
</view>
