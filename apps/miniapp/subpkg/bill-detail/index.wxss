.amount-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 32rpx;
  margin-bottom: 24rpx;
}

.detail-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: var(--color-selected);
  text-align: center;
  line-height: 96rpx;
  font-size: 48rpx;
}

.detail-type {
  margin-top: 20rpx;
  color: var(--color-text-sub);
}

.detail-amount {
  margin-top: 10rpx;
  color: var(--color-brand-deep);
  font-size: 64rpx;
  font-weight: 800;
}

.detail-amount--income {
  color: var(--color-income);
}

.detail-card {
  padding: 8rpx 28rpx;
}

.row {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--color-divider);
}

.row:last-child {
  border-bottom: 0;
}

.label {
  color: var(--color-text-sub);
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.danger-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: var(--color-error);
  color: #ffffff;
  font-weight: 600;
  text-align: center;
  line-height: 88rpx;
}
