.page {
  height: 100vh;
  background: #F0FBF5;
  display: flex;
  flex-direction: column;
}

/* 顶部固定控件 */
.toolbar {
  flex-shrink: 0;
  background: #F0FBF5;
  padding: 20rpx 24rpx 12rpx;
}

.content-scroll {
  flex: 1;
  height: 0;
  padding-bottom: 40rpx;
}

.segmented {
  display: flex;
  background: #E8F3EE;
  border-radius: 18rpx;
  padding: 4rpx;
  margin-bottom: 16rpx;
}

.seg-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #7A9E8E;
  padding: 12rpx 0;
  border-radius: 14rpx;
  transition: all .15s;
}

.seg-item--active {
  background: #FFFFFF;
  color: #2B8A57;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(93,190,136,0.15);
}

.period-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 14rpx 24rpx;
  margin-bottom: 16rpx;
}

.period-arrow {
  color: #5DBE88;
  font-size: 36rpx;
  padding: 0 24rpx;
}

.period-arrow--disabled {
  color: #C5D7CD;
}

.period-text {
  font-size: 30rpx;
  color: #1F2A24;
  font-weight: 600;
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93,190,136,0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2A24;
  margin-bottom: 24rpx;
}

/* 摘要卡 */
.summary-amount-label {
  font-size: 24rpx;
  color: #7A9E8E;
}

.summary-amount {
  font-size: 64rpx;
  font-weight: 700;
  color: #1F2A24;
  margin: 12rpx 0 16rpx;
  line-height: 1.1;
}

.summary-meta {
  display: flex;
  gap: 40rpx;
  font-size: 24rpx;
  color: #7A9E8E;
}

.summary-change--up {
  color: #E78A82;
}

.summary-change--down {
  color: #5DBE88;
}

/* 环形图 */
.ring-chart {
  width: 480rpx;
  height: 480rpx;
  margin: 0 auto;
  position: relative;
}

.ring-image {
  width: 480rpx;
  height: 480rpx;
  display: block;
}

.ring-canvas {
  width: 480rpx;
  height: 480rpx;
  display: block;
}

.ring-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
  margin-top: 24rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #1F2A24;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

/* 洞察卡 */
.insight-row {
  font-size: 26rpx;
  color: #1F2A24;
  background: #F7FBF9;
  border-left: 4rpx solid #5DBE88;
  padding: 16rpx 20rpx;
  border-radius: 0 12rpx 12rpx 0;
  margin-bottom: 12rpx;
}

.insight-row:last-child {
  margin-bottom: 0;
}

/* 排行榜 */
.rank-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F5F2;
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #E8F3EE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.rank-main {
  flex: 1;
  min-width: 0;
}

.rank-line1 {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.rank-name {
  font-size: 28rpx;
  color: #1F2A24;
  font-weight: 500;
}

.rank-amount {
  font-size: 28rpx;
  color: #1F2A24;
  font-weight: 600;
}

.rank-bar-wrap {
  height: 8rpx;
  background: #F0F5F2;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.rank-bar {
  height: 100%;
  background: #5DBE88;
  border-radius: 4rpx;
}

.rank-line2 {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: #7A9E8E;
}

.rank-line2 .rank-bar-wrap {
  flex: 1;
}

.rank-change--up {
  color: #E78A82;
}

.rank-change--down {
  color: #5DBE88;
}

/* mini 柱 */
.mini-bars {
  display: flex;
  align-items: flex-end;
  gap: 3rpx;
  width: 80rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.mini-bar {
  flex: 1;
  background: #D5E9DD;
  border-radius: 2rpx;
  min-height: 2rpx;
}

.mini-bar--last {
  background: #5DBE88;
}

/* TOP 单笔 */
.top-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F5F2;
}

.top-row:last-child {
  border-bottom: none;
}

.top-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #E8F3EE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.top-main {
  flex: 1;
  min-width: 0;
}

.top-line1 {
  font-size: 26rpx;
  color: #1F2A24;
  margin-bottom: 4rpx;
}

.top-line2 {
  font-size: 22rpx;
  color: #7A9E8E;
}

.top-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2A24;
}

/* 折线/热力 canvas */
.chart-frame {
  width: 100%;
  position: relative;
}

.chart-frame--line {
  height: 320rpx;
}

.chart-frame--heatmap {
  height: 360rpx;
}

.chart-image {
  width: 100%;
  display: block;
}

.chart-image--line {
  height: 320rpx;
}

.chart-image--heatmap {
  height: 360rpx;
}

.chart-canvas {
  width: 100%;
  height: 320rpx;
}

.heatmap-canvas {
  width: 100%;
  height: 360rpx;
}

/* 空态 */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7A9E8E;
  margin-bottom: 32rpx;
}

.empty-btn {
  display: inline-block;
  background: #5DBE88;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 24rpx;
}

/* 加载态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #7A9E8E;
  font-size: 26rpx;
}

/* 分类详情弹层 */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx 40rpx;
  z-index: 101;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2A24;
  margin-bottom: 8rpx;
  text-align: center;
}

.sheet-sub {
  font-size: 24rpx;
  color: #7A9E8E;
  text-align: center;
  margin-bottom: 16rpx;
}

.sheet-list {
  flex: 1;
  overflow-y: auto;
}
