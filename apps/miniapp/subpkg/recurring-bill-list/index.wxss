@import "../../styles/manage.wxss";

.swipe-row--tall {
  height: 164rpx;
}

.rb-card {
  height: 164rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 32rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 40rpx rgba(43, 74, 58, 0.09);
}

.swipe-content .rb-card {
  border-radius: 0;
}

.rb-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: var(--color-selected);
  font-size: 36rpx;
}

.rb-icon--inactive {
  background: #f5f5f5;
  opacity: 0.6;
}

.rb-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.rb-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-main);
}

.rb-repeat {
  font-size: 24rpx;
  color: var(--color-text-sub);
}

.rb-next {
  font-size: 22rpx;
  color: var(--color-text-weak);
}

.rb-next--none {
  color: #ccc;
}

.rb-amount {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 700;
  font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif;
  color: var(--color-text-main);
}

.rb-amount--income {
  color: var(--color-income);
}

.empty-state {
  padding: 96rpx 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: var(--color-text-sub);
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-weak);
}
