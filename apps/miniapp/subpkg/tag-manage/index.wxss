@import "../../styles/manage.wxss";

.swipe-content .manage-card {
  border-radius: 0;
}

.swipe-content .card-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
}

.tag-summary {
  font-family: inherit;
  font-size: 28rpx;
}

.tag-icon--green {
  background: var(--color-selected);
}

.tag-icon--orange {
  background: #fef3e8;
}

.tag-icon--blue {
  background: #e3f2fd;
}

.tag-icon--pink {
  background: #fff0f3;
}

.tag-icon--gray {
  background: var(--color-surface-soft);
}
