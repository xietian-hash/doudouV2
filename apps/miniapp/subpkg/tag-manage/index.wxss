@import '../../styles/manage.wxss';

.swipe-content .manage-card {
  border-radius: 0;
}

.swipe-content .card-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
}

.tag-summary {
  font-family: inherit;
  font-size: 28rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.card-title-row .card-title {
  min-width: 0;
}

.tag-type {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  color: var(--color-text-secondary);
  background: var(--color-surface-soft);
}

.tag-type--economic {
  color: var(--color-brand);
  background: var(--color-selected);
}

.tag-type--system {
  color: var(--color-warning);
  background: #fef3e8;
}

.tag-type--user {
  color: var(--color-text-secondary);
  background: var(--color-surface-soft);
}

.tag-icon--green {
  background: var(--color-selected);
}

.tag-icon--orange {
  background: #fef3e8;
}

.tag-icon--blue {
  background: #e3f2fd;
}

.tag-icon--pink {
  background: #fff0f3;
}

.tag-icon--gray {
  background: var(--color-surface-soft);
}
