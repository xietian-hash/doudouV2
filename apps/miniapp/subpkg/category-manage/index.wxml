<view class="page category-page">
  <view class="head-row">
    <text class="title">分类</text>
    <view class="primary-small" bindtap="openCreate">新增分类</view>
  </view>
  <view class="tabs">
    <view class="tab {{type === 1 ? 'tab--active' : ''}}" data-type="1" bindtap="switchType">支出</view>
    <view class="tab {{type === 2 ? 'tab--active tab--income' : ''}}" data-type="2" bindtap="switchType">收入</view>
  </view>
  <view wx:for="{{categories}}" wx:key="id" class="item card" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="openChildren">
    <text class="item-icon">{{item.icon || '□'}}</text>
    <view class="item-main">
      <text class="item-title">{{item.name}}</text>
      <text class="item-sub">{{item.children ? item.children.length : 0}} 个子分类</text>
    </view>
    <text class="item-action">管理</text>
    <text class="item-delete" catchtap="remove" data-id="{{item.id}}">删除</text>
  </view>

  <view wx:if="{{dialogVisible}}" class="dialog-mask">
    <view class="dialog card">
      <text class="dialog-title">新增一级分类</text>
      <input class="input" value="{{form.name}}" bindinput="onNameInput" placeholder="分类名称" />
      <input class="input input--mt" value="{{form.icon}}" bindinput="onIconInput" placeholder="图标 Emoji，可不填" />
      <view class="dialog-actions">
        <view class="secondary-btn" bindtap="closeDialog">取消</view>
        <view class="primary-btn" bindtap="save">确认</view>
      </view>
    </view>
  </view>
</view>
