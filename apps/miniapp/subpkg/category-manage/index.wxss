@import "../../styles/manage.wxss";

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-sub);
  text-align: center;
  line-height: 72rpx;
  font-weight: 700;
}

.tab--active {
  background: var(--color-selected);
  color: var(--color-brand-deep);
}

.tab--income {
  color: var(--color-income);
}

.input--mt {
  margin-top: 18rpx;
}
