@import "./styles/tokens.wxss";

page {
  min-height: 100%;
  background: var(--color-bg-page);
  color: var(--color-text-main);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
scroll-view,
input,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.4;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 160rpx;
}

.card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-divider);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(43, 74, 58, 0.06);
}

.primary-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: var(--color-brand);
  color: #ffffff;
  font-weight: 600;
  text-align: center;
  line-height: 88rpx;
}

.secondary-btn {
  height: 88rpx;
  border: 1rpx solid var(--color-divider);
  border-radius: 24rpx;
  background: #ffffff;
  color: var(--color-brand);
  font-weight: 600;
  text-align: center;
  line-height: 88rpx;
}

.danger-text {
  color: var(--color-error);
}
